{
  "manifest_version": 3,
  "name": "Meerkat",
  "version": "0.1.2",
  "description": "Shows GitHub PR author statistics for maintainers.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.github.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "assets/icons/meerkat-16.png",
    "32": "assets/icons/meerkat-32.png",
    "48": "assets/icons/meerkat-48.png",
    "128": "assets/icons/meerkat-128.png"
  },
  "action": {
    "default_title": "Meerkat",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icons/meerkat-16.png",
      "32": "assets/icons/meerkat-32.png",
      "48": "assets/icons/meerkat-48.png",
      "128": "assets/icons/meerkat-128.png"
    }
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
